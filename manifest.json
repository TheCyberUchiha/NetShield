{
  "manifest_version": 3,
  "name": "NetShield",
  "version": "6.0.0",
  "description": "Advanced productivity firewall: Lock distracting domains and enforce focus with NetShield.",
  "icons": {
    "16": "Logo.png",
    "48": "Logo.png",
    "128": "Logo.png"
  },
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "alarms",
    "scripting",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "Logo.png",
      "48": "Logo.png",
      "128": "Logo.png"
    }
  },
  "background": {
    "service_worker": "src/background/serviceWorker.ts",
    "type": "module"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["src/content/timerWidget.ts"],
    "run_at": "document_idle"
  }],
  "web_accessible_resources": [{
    "resources": ["block.html", "Logo.png"],
    "matches": ["chrome-extension://*/*"]
  }],
  "content_security_policy": {
    "extension_pages": "default-src 'none'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; object-src 'none'; frame-ancestors 'none';"
  }
}
